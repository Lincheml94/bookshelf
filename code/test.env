NODE_ENV=test
PORT=3000

# reprendre strictement le nom du service docker MySql
MYSQL_HOST=mysql
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=publishinghouse_test                 

# reprendre strictement le nom du service docker Mongodb
MONGODB_HOST=mongodb
MONGODB_USER=root
MONGODB_PASSWORD=root
MONGODB_DATABASE=publishinghouse_test

# URL de l'API
# Si la variable doit être utilisée dans vite, il est nécessaire de préfixer la variable par VITE_
VITE_API_URL=http://127.0.0.1:3000

#origines autorisées - CORS
ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# DOSSIER PUBLIC 
PUBLIC_DIR=tests/public

# Signature du JWT
# 256 caractères recommandés
VITE_JWT_SECRET=secret